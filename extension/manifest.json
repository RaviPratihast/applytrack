{
  "manifest_version": 3,
  "name": "ApplyTrack",
  "version": "1.0.0",
  "description": "Save job applications to your ApplyTrack dashboard while you apply.",
  "permissions": ["storage", "activeTab"],
  "host_permissions": [
    "http://localhost:3001/*",
    "https://*.linkedin.com/*",
    "https://*.indeed.com/*",
    "https://*.greenhouse.io/*",
    "https://*.lever.co/*",
    "https://jobs.lever.co/*",
    "https://*.workday.com/*",
    "https://wellfound.com/*",
    "https://www.wellfound.com/*",
    "https://careers.kula.ai/*"
  ],
  "background": {
    "service_worker": "dist/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.linkedin.com/*",
        "https://linkedin.com/*",
        "https://*.indeed.com/*",
        "https://*.greenhouse.io/*",
        "https://*.lever.co/*",
        "https://jobs.lever.co/*",
        "https://*.workday.com/*",
        "https://wellfound.com/*",
        "https://www.wellfound.com/*",
        "https://careers.kula.ai/*"
      ],
      "js": ["dist/content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "ApplyTrack"
  }
}
